{
  "name": "gitpeek",
  "version": "0.0.0",
  "description": "Lightweight git worktree visualizer — open from CLI, commit, push, close.",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexprudhomme/gitpeek.git",
    "directory": "packages/gitpeek"
  },
  "scripts": {
    "dev": "electrobun dev",
    "dev:browser": "bun run src/dev-server.ts . & vite --config vite.config.browser.ts",
    "build": "electrobun build --env=stable",
    "test": "bun test",
    "start:packaged": "open build/stable-macos-arm64/GitPeek.app"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electrobun": "^1.14.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "bun-types": "^1.2.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  },
  "packageManager": "bun@1.3.11"
}
